{
  "manifest_version": 3,
  "name": "MerchWizard Pro - Research Assistant",
  "version": "1.0.0",
  "description": "The ultimate research tool for Merch by Amazon. Track BSR, download assets, and optimize listings.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeContent",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.amazon.com/*", "https://*.amazon.co.uk/*", "https://*.amazon.de/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
